<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Products</title>

<style>
body{font-family:Arial;background:#f1f3f6;margin:0}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:10px}
.product{background:#fff;padding:10px;border-radius:10px;text-align:center}
.product img{width:100%;height:120px;object-fit:contain}
.price{color:green;font-weight:bold}
</style>
</head>

<body>

<h2 id="title" style="text-align:center"></h2>

<div class="grid" id="productList"></div>

<script>

// URL se category nikaalna
let urlParams = new URLSearchParams(window.location.search);
let category = urlParams.get("cat");

document.getElementById("title").innerText = category.toUpperCase();

// Products data
let data = {

transistor: [
 {name:"2N3055", price:50, img:"https://via.placeholder.com/150"},
 {name:"C1815", price:10, img:"https://via.placeholder.com/150"}
],

mosfet: [
 {name:"IRFZ44N", price:60, img:"https://via.placeholder.com/150"},
 {name:"IRFP250", price:80, img:"https://via.placeholder.com/150"}
],

capacitor: [
 {name:"450V Capacitor", price:30, img:"https://via.placeholder.com/150"}
],

pcb: [
 {name:"Induction PCB Board", price:300, img:"https://via.placeholder.com/150"}
]

};

// Show products
let html="";
(data[category] || []).forEach(p=>{
 html+=`
 <div class="product">
   <img src="${p.img}">
   <h4>${p.name}</h4>
   <p class="price">₹${p.price}</p>
   <button onclick="buy('${p.name}',${p.price})">Buy</button>
 </div>`;
});

document.getElementById("productList").innerHTML = html;

// UPI payment
function function buy(name, price){

  let state = prompt("Enter your State (Delhi / Other)");

  if(!state){
    alert("State required");
    return;
  }

  let delivery = 150;

  if(state.toLowerCase() === "delhi"){
    delivery = 100;
  }

  let total = price + delivery;

  // Minimum order check
  if(total < 500){
    alert("Minimum order ₹500 hona chahiye");
    return;
  }

  let confirmOrder = confirm(
    "Product: " + name +
    "\nPrice: ₹" + price +
    "\nDelivery: ₹" + delivery +
    "\nTotal: ₹" + total +
    "\n\nProceed to payment?"
  );

  if(!confirmOrder) return;

  let upi="9953311542@ybl";

  let url=`upi://pay?pa=${upi}&pn=ElectroElectric&am=${total}&cu=INR`;

  window.location.href = url;
}

</script>

</body>
</html>
